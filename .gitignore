# ── 数据集（体积大，不入库）──────────────────────────────────────
data/
datasets/

# ── 模型权重文件（体积大，不入库）────────────────────────────────
# 只忽略 .pt/.pth 权重文件本身，放行目录结构和 CSV 结果
*.pt
*.pth
checkpoints/

# weights/ 目录: 忽略权重文件，但放行 metrics/ 下的 CSV
weights/**/*.pt
weights/**/*.pth

# ── Python 编译缓存（忽略）───────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── 虚拟环境 & IDE（忽略）────────────────────────────────────────
venv/
.env
.vscode/
.idea/

# ── 其他杂项（忽略）──────────────────────────────────────────────
.claude/
结果表.et
project_structure.txt
